{
  "name": "@eyueldk/aisdk-toolkit-browser",
  "version": "2.1.0",
  "description": "Puppeteer browser toolkit (AI SDK tools + session) for the Vercel AI SDK",
  "license": "MIT",
  "author": "Eyuel G. Molla",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
